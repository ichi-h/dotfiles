{
  "mcpServers": {
    "serena": {
      "type": "local",
      "command": "serena",
      "tools": [
        "*"
      ],
      "args": [
        "start-mcp-server",
        "--context",
        "ide",
        "--enable-web-dashboard",
        "false"
      ]
    },
    "git": {
      "type": "local",
      "command": "mcp-server-git",
      "tools": [
        "*"
      ],
      "args": []
    },
    "notifier": {
      "type": "local",
      "command": "node",
      "tools": [
        "*"
      ],
      "args": [
        "--env-file=${HOME}/dotfiles/notifier-mcp/.env",
        "${HOME}/dotfiles/notifier-mcp/src/index.js"
      ]
    }
  }
}
