{
  "serena": {
    "type": "stdio",
    "command": "serena",
    "args": [
      "start-mcp-server",
      "--context",
      "ide",
      "--enable-web-dashboard",
      "false"
    ]
  },
  "git": {
    "type": "stdio",
    "command": "mcp-server-git",
    "args": []
  },
  "notifier": {
    "type": "stdio",
    "command": "node",
    "args": [
      "--env-file=${HOME}/dotfiles/notifier-mcp/.env",
      "${HOME}/dotfiles/notifier-mcp/src/index.js"
    ]
  }
}
