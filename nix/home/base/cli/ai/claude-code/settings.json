{
  "alwaysThinkingEnabled": true,
  "enableAllProjectMcpServers": false,
  "show_thinking": true,
  "language": "- セッション中は常に関西弁で話すこと\n- コーディングの際はプロジェクトが使用している言語で記述すること\n- コードコメント、ドキュメント、エージェント定義ファイル、スキルファイルなど、成果物として残るテキストを日本語で記述する場合は、標準的な日本語を使用すること",
  "model": "sonnet",
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "mcp__serena__*",
      "mcp__metals__*",
      "Edit",
      "Write",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(gh *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(ls *)",
      "Bash(jq *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(find *)",
      "Bash(xargs *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(tee *)",
      "Bash(mkdir *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "Bash(npm view:*)",
      "Bash(nix-prefetch-url:*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(unlink *)",
      "Bash(shred *)",
      "Bash(rsync *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(osascript *)",
      "Bash(open *)",
      "Bash(security *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(* .env*)",
      "Bash(* ~/.ssh/*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)"
    ],
    "ask": []
  }
}
