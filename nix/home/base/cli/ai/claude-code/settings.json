{
  "alwaysThinkingEnabled": true,
  "enableAllProjectMcpServers": false,
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "mcp__serena__*",
      "mcp__metals__*",
      "Edit",
      "Write",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(gh *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(ls *)",
      "Bash(jq *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(find *)",
      "Bash(xargs *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(tee *)",
      "Bash(mkdir *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "Bash(npm view:*)",
      "Bash(nix-prefetch-url:*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(unlink *)",
      "Bash(shred *)",
      "Bash(rsync *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(osascript *)",
      "Bash(open *)",
      "Bash(security *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(python3 *)",
      "Bash(node *)"
    ],
    "ask": []
  }
}
